{
  "name": "bbjf-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "verify:project": "bash scripts/verify-project.sh",
    "safe-export": "bash scripts/safe-export.sh",
    "check-safe-archive": "bash scripts/check-safe-archive.sh",
    "lock:sync": "npm install --package-lock-only",
    "cleanup:starter": "bash scripts/cleanup-unused-starter-files.sh",
    "cleanup:payment": "bash scripts/cleanup-bbjf-payment-remnants.sh",
    "security:audit": "npm audit --audit-level=high",
    "security:audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify:production": "bash scripts/verify-production-readiness.sh",
    "scan:secrets": "bash scripts/scan-secrets.sh"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "nitro": "^3.0.260429-beta",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "supabase": "^2.100.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  },
  "allowScripts": {
    "core-js@3.49.0": true
  }
}
