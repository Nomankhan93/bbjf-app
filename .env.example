# BBJF public Supabase client values. Safe placeholder values only.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional public site URL used by deployment/check scripts.
VITE_PUBLIC_SITE_URL=https://your-bbjf-domain.example

# Server-only secret. Never expose this in client code, Git, or shared ZIP files.
# Configure it only in your deployment provider / local .env.local.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
